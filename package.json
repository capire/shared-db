{
  "name": "@capire/shared-db",
  "version": "3.0.0",
  "description": "CAP Sample CDS model deployment for shared-db scenario",
  "dependencies": {
    "@capire/bookstore": "*",
    "@capire/orders": "*",
    "@capire/reviews": "*",
    "@sap/cds-mtxs": "3.6.0"
  },
  "cds": {
    "sql": {
      "native_hana_associations": false
    },
    "profile": "with-mtx-sidecar",
    "requires": {
      "[production]": {
        "multitenancy": true
      },
      "[with-mtx]": {
        "multitenancy": true
      },
      "extensibility": true
    }
  }
}
